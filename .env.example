# ───────────────────────────────────────────────────────────────────
# Backend environment — copy to .env and fill in.
# ───────────────────────────────────────────────────────────────────

# Postgres (Neon recommended). Pooler URL works for runtime.
DATABASE_URL=postgresql://username:password@localhost:5432/scrolt

# Server
PORT=4000
NODE_ENV=development

# Upstash Redis (REST). Free tier is fine for dev.
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Comma-separated allowed origins for CORS.
# Localhost dev origins are always allowed in NODE_ENV=development.
CORS_ORIGINS=https://scrolt.vercel.app

# Auth.js shared secret. MUST match frontend AUTH_SECRET.
# Generate with:  npx auth secret    (or: openssl rand -base64 32)
AUTH_SECRET=replace-me-with-a-32-byte-random-string
